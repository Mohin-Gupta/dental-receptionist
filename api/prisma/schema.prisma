generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id               String   @id @default(uuid())
  organizationId   String
  name             String
  phone            String
  timezone         String   @default("UTC")
  googleCalendarId String?
  googleTokens     String?
  businessHours    Json
  lastAgendaSentDate String?

  clinicAddress     String?
  clinicEmail       String?
  clinicWebsite     String?
  clinicServices    Json?   // array of services offered
  clinicAbout       String? // short description

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patients     Patient[]
  appointments Appointment[]
  callLogs     CallLog[]
  memberships  ClinicMembership[]
  inviteTokens InviteToken[]
  auditLogs    AuditLog[]
  securityEvents SecurityEvent[]
  doctors      DoctorClinic[]
  doctorAvailabilities DoctorAvailability[]
  calendarConnections CalendarConnection[]
  // escalations  Escalation[]
  // callbacks    Callback[]

  @@unique([organizationId, phone])
  @@index([organizationId])
}

model Organization {
  id             String   @id @default(uuid())
  name           String
  phone          String?
  email          String?
  website        String?
  about          String?
  services       Json?
  planTier       String   @default("starter")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinics        Clinic[]
  patients       Patient[]
  appointments   Appointment[]
  callLogs       CallLog[]
  memberships    OrganizationMembership[]
  doctors        Doctor[]
  inviteTokens   InviteToken[]
  auditLogs      AuditLog[]
  securityEvents SecurityEvent[]
  calendarConnections CalendarConnection[]
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String
  passwordHash    String
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  status          String    @default("active")
  mfaRequired     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships             ClinicMembership[]
  organizationMemberships OrganizationMembership[]
  sessions                Session[]
  createdInvites          InviteToken[]            @relation("InviteCreatedBy")
  acceptedInvites         InviteToken[]            @relation("InviteAcceptedBy")
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  mfaMethods              MfaMethod[]
  doctorProfiles          Doctor[]
  auditLogs               AuditLog[]
  securityEvents          SecurityEvent[]
}

model OrganizationMembership {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String   @default("viewer")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role])
}

model ClinicMembership {
  id        String   @id @default(uuid())
  userId    String
  clinicId  String
  role      String   @default("staff")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@index([clinicId, role])
}

model Session {
  id            String    @id @default(uuid())
  userId        String
  tokenHash     String    @unique
  csrfTokenHash String?
  expiresAt     DateTime
  lastSeenAt    DateTime  @default(now())
  revokedAt     DateTime?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model InviteToken {
  id           String    @id @default(uuid())
  organizationId String
  clinicId     String?
  email        String
  organizationRole String?
  clinicRole   String?
  tokenHash    String    @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdById  String?
  acceptedById String?
  createdAt    DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic     Clinic? @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdBy  User?  @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  acceptedBy User?  @relation("InviteAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([organizationId, email])
  @@index([clinicId, email])
}

model Doctor {
  id              String   @id @default(uuid())
  organizationId  String
  userId          String?  @unique
  name            String
  phone           String?
  email           String?
  qualification   String?
  yearsExperience Int?
  specialty       String?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  clinics      DoctorClinic[]
  availabilities DoctorAvailability[]
  appointments Appointment[]
  calendarConnections CalendarConnection[]

  @@index([organizationId, status])
}

model DoctorClinic {
  id        String   @id @default(uuid())
  doctorId  String
  clinicId  String
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([doctorId, clinicId])
  @@index([clinicId])
}

model DoctorAvailability {
  id        String   @id @default(uuid())
  doctorId  String
  clinicId  String?
  dayOfWeek Int
  open      String
  close     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([doctorId, clinicId, dayOfWeek])
}

model CalendarConnection {
  id             String   @id @default(uuid())
  organizationId String
  clinicId       String?
  doctorId       String?
  scope          String
  googleCalendarId String?
  googleTokens   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic       Clinic?      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor       Doctor?      @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([organizationId, scope])
  @@index([clinicId])
  @@index([doctorId])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model MfaMethod {
  id            String    @id @default(uuid())
  userId        String
  type          String
  secret        String?
  recoveryCodes Json?
  enabledAt     DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  organizationId String?
  clinicId   String?
  action     String
  targetType String?
  targetId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([clinicId, createdAt])
  @@index([userId, createdAt])
}

model SecurityEvent {
  id        String   @id @default(uuid())
  userId    String?
  organizationId String?
  clinicId  String?
  type      String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
}

model Patient {
  id        String   @id @default(uuid())
  organizationId String
  clinicId  String
  name      String
  phone     String
  email     String?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  callLogs     CallLog[]

  @@unique([organizationId, phone])
  @@index([clinicId])
}

model Appointment {
  id            String   @id @default(uuid())
  organizationId String
  clinicId      String
  doctorId      String
  patientId     String
  reason        String
  startAt       DateTime
  endAt         DateTime
  status        String   @default("scheduled")
  googleEventId String?
  // confirmed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor       Doctor        @relation(fields: [doctorId], references: [id])
  patient      Patient       @relation(fields: [patientId], references: [id])
  callLogs     CallLog[]
  reminderJobs ReminderJob[]
  // callbacks    Callback[]

  @@index([organizationId, startAt])
  @@index([clinicId, startAt])
  @@index([doctorId, startAt])
}

model CallLog {
  id              String   @id @default(uuid())
  phoneNumber     String?
  organizationId  String
  clinicId        String
  patientId       String?
  appointmentId   String?
  vapiCallId      String   @unique
  direction       String   @default("inbound")
  durationSecs    Int?
  // confidenceScore Float?
  transcript      Json?
  outcome         String?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient?     @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  // escalation  Escalation?
}

