generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id               String   @id @default(uuid())
  name             String
  phone            String   @unique
  timezone         String   @default("UTC")
  googleCalendarId String?
  googleTokens     String?
  businessHours    Json
  // aiPersonality    Json
  planTier         String   @default("starter")
  lastAgendaSentDate String?
  // Doctor information
  doctorName        String?
  doctorPhone       String?
  doctorQualification String?
  doctorYOE         Int?
  doctorSpecialty   String?

  // Clinic information
  clinicAddress     String?
  clinicEmail       String?
  clinicWebsite     String?
  clinicServices    Json?   // array of services offered
  clinicAbout       String? // short description

  createdAt DateTime @default(now())

  patients     Patient[]
  appointments Appointment[]
  callLogs     CallLog[]
  // escalations  Escalation[]
  // callbacks    Callback[]
}

model Patient {
  id        String   @id @default(uuid())
  clinicId  String
  name      String
  phone     String
  email     String?
  createdAt DateTime @default(now())

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  callLogs     CallLog[]

  @@unique([clinicId, phone])
}

model Appointment {
  id            String   @id @default(uuid())
  clinicId      String
  patientId     String
  reason        String
  startAt       DateTime
  endAt         DateTime
  status        String   @default("scheduled")
  googleEventId String?
  // confirmed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id])
  callLogs     CallLog[]
  reminderJobs ReminderJob[]
  // callbacks    Callback[]

  @@index([clinicId, startAt])
}

model CallLog {
  id              String   @id @default(uuid())
  phoneNumber     String?
  clinicId        String
  patientId       String?
  appointmentId   String?
  vapiCallId      String   @unique
  direction       String   @default("inbound")
  durationSecs    Int?
  // confidenceScore Float?
  transcript      Json?
  outcome         String?
  createdAt       DateTime @default(now())

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient?     @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  // escalation  Escalation?
}

