generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id                 String    @id @default(uuid())
  organizationId     String
  name               String
  phone              String
  timezone           String    @default("UTC")
  countryCode        String    @default("IN")
  defaultCallingCode String    @default("91")
  locale             String    @default("en-IN")
  status             String    @default("active")
  archivedAt         DateTime?
  googleCalendarId   String?
  googleTokens       String?
  businessHours      Json
  lastAgendaSentDate String?

  clinicAddress  String?
  clinicEmail    String?
  clinicWebsite  String?
  clinicServices Json? // array of services offered
  clinicAbout    String? // short description

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patients                 Patient[]
  appointments             Appointment[]
  callLogs                 CallLog[]
  memberships              ClinicMembership[]
  inviteTokens             InviteToken[]
  auditLogs                AuditLog[]
  securityEvents           SecurityEvent[]
  doctors                  DoctorClinic[]
  doctorAvailabilities     DoctorAvailability[]
  calendarConnections      CalendarConnection[]
  reminderJobs             ReminderJob[]
  providerResources        ProviderResource[]
  communicationAttempts    CommunicationAttempt[]
  communicationPreferences CommunicationPreference[]
  usageEvents              UsageEvent[]
  providerCostEntries      ProviderCostEntry[]
  tenantBudgets            TenantBudget[]
  budgetAlertDeliveries    BudgetAlertDelivery[]
  outboxEvents             OutboxEvent[]
  // escalations  Escalation[]
  // callbacks    Callback[]

  @@unique([organizationId, phone])
  @@unique([id, organizationId])
  @@index([organizationId])
  @@index([organizationId, status])
}

model Organization {
  id         String   @id @default(uuid())
  name       String
  phone      String?
  email      String?
  website    String?
  about      String?
  services   Json?
  planTier   String   @default("starter")
  status     String   @default("provisioning")
  dataRegion String   @default("IN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  clinics                  Clinic[]
  patients                 Patient[]
  appointments             Appointment[]
  callLogs                 CallLog[]
  memberships              OrganizationMembership[]
  clinicMemberships        ClinicMembership[]
  doctors                  Doctor[]
  doctorClinics            DoctorClinic[]
  doctorAvailabilities     DoctorAvailability[]
  inviteTokens             InviteToken[]
  reminderJobs             ReminderJob[]
  auditLogs                AuditLog[]
  securityEvents           SecurityEvent[]
  calendarConnections      CalendarConnection[]
  providerAccounts         ProviderAccount[]
  providerResources        ProviderResource[]
  communicationAttempts    CommunicationAttempt[]
  communicationPreferences CommunicationPreference[]
  providerWebhookEvents    ProviderWebhookEvent[]
  usageEvents              UsageEvent[]
  providerCostEntries      ProviderCostEntry[]
  billingAccount           BillingAccount?
  billingCheckoutSessions  BillingCheckoutSession[]
  subscriptions            SubscriptionMirror[]
  entitlements             Entitlement[]
  tenantBudgets            TenantBudget[]
  budgetAlertDeliveries    BudgetAlertDelivery[]
  budgetAlertIssues        BudgetAlertEvaluationIssue[]
  usageExports             UsageExport[]
  outboxEvents             OutboxEvent[]
  reconciliationRuns       ReconciliationRun[]
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String
  passwordHash    String
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  status          String    @default("active")
  mfaRequired     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships             ClinicMembership[]
  organizationMemberships OrganizationMembership[]
  sessions                Session[]
  createdInvites          InviteToken[]            @relation("InviteCreatedBy")
  acceptedInvites         InviteToken[]            @relation("InviteAcceptedBy")
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  mfaMethods              MfaMethod[]
  doctorProfiles          Doctor[]
  auditLogs               AuditLog[]
  securityEvents          SecurityEvent[]
  budgetAlertDeliveries   BudgetAlertDelivery[]
}

model OrganizationMembership {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String   @default("viewer")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role])
}

model ClinicMembership {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  clinicId       String
  role           String   @default("staff")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic       Clinic       @relation(fields: [clinicId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@index([organizationId, userId])
  @@index([clinicId, role])
}

model Session {
  id            String    @id @default(uuid())
  userId        String
  tokenHash     String    @unique
  csrfTokenHash String?
  mfaVerifiedAt DateTime?
  expiresAt     DateTime
  lastSeenAt    DateTime  @default(now())
  revokedAt     DateTime?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model InviteToken {
  id               String    @id @default(uuid())
  organizationId   String
  clinicId         String?
  email            String
  organizationRole String?
  clinicRole       String?
  tokenHash        String    @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  createdById      String?
  acceptedById     String?
  createdAt        DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic       Clinic?      @relation(fields: [clinicId, organizationId], references: [id, organizationId], onDelete: Cascade)
  createdBy    User?        @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  acceptedBy   User?        @relation("InviteAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([organizationId, email])
  @@index([clinicId, email])
}

model Doctor {
  id              String   @id @default(uuid())
  organizationId  String
  userId          String?  @unique
  name            String
  phone           String?
  email           String?
  qualification   String?
  yearsExperience Int?
  specialty       String?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  clinics             DoctorClinic[]
  availabilities      DoctorAvailability[]
  appointments        Appointment[]
  calendarConnections CalendarConnection[]

  @@unique([id, organizationId])
  @@index([organizationId, status])
}

model DoctorClinic {
  id             String   @id @default(uuid())
  organizationId String
  doctorId       String
  clinicId       String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  doctor       Doctor       @relation(fields: [doctorId, organizationId], references: [id, organizationId], onDelete: Cascade)
  clinic       Clinic       @relation(fields: [clinicId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@unique([doctorId, clinicId])
  @@unique([organizationId, doctorId, clinicId])
  @@index([organizationId, clinicId])
}

model DoctorAvailability {
  id             String   @id @default(uuid())
  organizationId String
  doctorId       String
  clinicId       String?
  dayOfWeek      Int
  open           String
  close          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  doctor       Doctor       @relation(fields: [doctorId, organizationId], references: [id, organizationId], onDelete: Cascade)
  clinic       Clinic?      @relation(fields: [clinicId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@index([organizationId, doctorId, clinicId, dayOfWeek], map: "DoctorAvailability_tenant_doctor_clinic_day_idx")
}

model CalendarConnection {
  id               String   @id @default(uuid())
  organizationId   String
  clinicId         String?
  doctorId         String?
  scope            String
  googleCalendarId String?
  googleTokens     String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic       Clinic?      @relation(fields: [clinicId, organizationId], references: [id, organizationId], onDelete: Cascade)
  doctor       Doctor?      @relation(fields: [doctorId, organizationId], references: [id, organizationId], onDelete: Cascade)

  @@index([organizationId, scope])
  @@index([clinicId])
  @@index([doctorId])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

/// Durable replay protection for unauthenticated self-service tenant creation.
/// Only hashes and result identifiers are retained; request bodies and
/// passwords are never stored in this record.
model OrganizationRegistrationRequest {
  id                         String    @id @default(uuid())
  idempotencyKeyHash         String    @unique
  requestHash                String
  status                     String    @default("processing")
  userId                     String?
  organizationId             String?
  clinicId                   String?
  verificationDeliveryStatus String    @default("pending")
  completedAt                DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([organizationId])
}

model MfaMethod {
  id            String    @id @default(uuid())
  userId        String
  type          String
  secret        String?
  recoveryCodes Json?
  enabledAt     DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?
  organizationId String?
  clinicId       String?
  action         String
  targetType     String?
  targetId       String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  clinic       Clinic?       @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([clinicId, createdAt])
  @@index([userId, createdAt])
}

model SecurityEvent {
  id             String   @id @default(uuid())
  userId         String?
  organizationId String?
  clinicId       String?
  type           String
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  clinic       Clinic?       @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
}

model Patient {
  id             String   @id @default(uuid())
  organizationId String
  clinicId       String
  name           String
  phone          String
  email          String?
  createdAt      DateTime @default(now())

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic                Clinic                 @relation(fields: [clinicId, organizationId], references: [id, organizationId], onDelete: Cascade)
  appointments          Appointment[]
  callLogs              CallLog[]
  communicationAttempts CommunicationAttempt[]

  @@unique([organizationId, phone])
  @@unique([id, organizationId])
  @@index([clinicId])
}

model Appointment {
  id                      String   @id @default(uuid())
  organizationId          String
  clinicId                String
  doctorId                String
  patientId               String
  reason                  String
  startAt                 DateTime @db.Timestamptz(3)
  endAt                   DateTime @db.Timestamptz(3)
  status                  String   @default("scheduled")
  googleEventId           String?
  version                 Int      @default(1)
  idempotencyKey          String?  @unique
  supersedesAppointmentId String?
  calendarSyncStatus      String   @default("pending")
  // confirmed     Boolean  @default(false)
  createdAt               DateTime @default(now())

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic                Clinic                 @relation(fields: [clinicId, organizationId], references: [id, organizationId], onDelete: Cascade)
  doctor                Doctor                 @relation(fields: [doctorId, organizationId], references: [id, organizationId])
  patient               Patient                @relation(fields: [patientId, organizationId], references: [id, organizationId])
  callLogs              CallLog[]
  reminderJobs          ReminderJob[]
  communicationAttempts CommunicationAttempt[]
  supersedes            Appointment?           @relation("AppointmentSupersession", fields: [supersedesAppointmentId, organizationId], references: [id, organizationId], onDelete: NoAction)
  supersededBy          Appointment[]          @relation("AppointmentSupersession")
  // callbacks    Callback[]

  @@unique([id, organizationId])
  @@unique([id, organizationId, clinicId])
  @@index([organizationId, startAt])
  @@index([clinicId, startAt])
  @@index([doctorId, startAt])
}

model CallLog {
  id                 String    @id @default(uuid())
  phoneNumber        String?
  organizationId     String
  clinicId           String
  patientId          String?
  appointmentId      String?
  vapiCallId         String    @unique
  direction          String    @default("inbound")
  durationSecs       Int?
  // confidenceScore Float?
  transcript         Json?
  transcriptPurgedAt DateTime?
  outcome            String?
  createdAt          DateTime  @default(now())

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic                Clinic                 @relation(fields: [clinicId, organizationId], references: [id, organizationId], onDelete: Cascade)
  patient               Patient?               @relation(fields: [patientId, organizationId], references: [id, organizationId])
  appointment           Appointment?           @relation(fields: [appointmentId, organizationId, clinicId], references: [id, organizationId, clinicId])
  communicationAttempts CommunicationAttempt[]
  // escalation  Escalation?

  @@unique([id, organizationId])
  @@index([organizationId, createdAt])
  @@index([clinicId, createdAt])
  @@index([transcriptPurgedAt, createdAt])
}

