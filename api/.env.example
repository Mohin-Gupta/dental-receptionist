# Copy to .env only for local development. In production, inject these values
# from a managed secret/config store; never bake this file into an image.

# -----------------------------------------------------------------------------
# Process and public origins
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3001
APP_NAME=Dental Receptionist
WEB_ORIGIN=https://app.example.com
PUBLIC_API_URL=https://api.example.com
# Set this to the exact number of trusted reverse proxies between the client
# and Express. Do not increase it speculatively.
TRUST_PROXY_HOPS=1
# Admission and parser ceilings. Keep matching limits at the ingress proxy.
WEBHOOK_REQUESTS_PER_MINUTE=600
JSON_BODY_LIMIT_BYTES=1048576
URLENCODED_BODY_LIMIT_BYTES=262144

# -----------------------------------------------------------------------------
# Durable data and queues (TLS endpoints are expected in production)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://app_user:REPLACE_ME@postgres.example.internal:5432/dental_receptionist?sslmode=require
REDIS_URL=rediss://default:REPLACE_ME@redis.example.internal:6379/0
TENANT_API_REQUESTS_PER_MINUTE=600
TENANT_API_MAX_CONCURRENT_REQUESTS=25

# -----------------------------------------------------------------------------
# Operations status and background-worker freshness
# -----------------------------------------------------------------------------
# Generate independently with `openssl rand -base64 48`. Restrict the status
# endpoint at the network layer too, and never put this token in browser code.
OPERATIONS_BEARER_TOKEN=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
WORKER_HEARTBEAT_NAME=background-worker
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_MAX_AGE_SECONDS=90
# Must be explicitly true or false in production. True keeps an API replica
# out of service when the named worker heartbeat is missing or stale.
REQUIRE_WORKER_HEARTBEAT_FOR_READINESS=true

# -----------------------------------------------------------------------------
# Authentication, cookies, email, and legal-consent versions
# -----------------------------------------------------------------------------
SESSION_COOKIE_NAME=__Host-dr_session
SESSION_TTL_DAYS=14
INVITE_TTL_HOURS=72
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_VERIFY_TTL_HOURS=24
MFA_SENSITIVE_WINDOW_MINUTES=30
OAUTH_STATE_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
CALLER_VERIFICATION_HMAC_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
# Generate each value with `openssl rand -base64 32`. Keep old key IDs during
# rotation so existing opt-outs remain enforceable; new writes migrate hashes.
COMMUNICATION_PREFERENCE_HMAC_ACTIVE_KEY_ID=pref-2026-07
COMMUNICATION_PREFERENCE_HMAC_KEYS={"pref-2026-07":"REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY"}
TERMS_VERSION=2026-07-13
PRIVACY_VERSION=2026-07-13

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
SMTP_FROM=Dental Receptionist <no-reply@example.com>

# One-time owner bootstrap only. Set these for the bootstrap job, then remove
# them from the long-lived API and worker environments.
# AUTH_BOOTSTRAP_EMAIL=owner@example.com
# AUTH_BOOTSTRAP_PASSWORD=REPLACE_WITH_A_UNIQUE_LONG_PASSWORD
# AUTH_BOOTSTRAP_NAME=Initial Owner
# AUTH_BOOTSTRAP_CLINIC_ID=REPLACE_WITH_EXISTING_CLINIC_ID

# -----------------------------------------------------------------------------
# Envelope encryption
# -----------------------------------------------------------------------------
# Generate a key with: openssl rand -base64 32
# Keep old key IDs in the JSON object during rotation. The active ID must exist.
DATA_ENCRYPTION_ACTIVE_KEY_ID=key-2026-07
DATA_ENCRYPTION_KEYS={"key-2026-07":"REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY"}

# -----------------------------------------------------------------------------
# Google Calendar OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_REDIRECT_URI=https://api.example.com/api/auth/google/callback

# These are explicit PHI/contract gates. Leave both false unless the deployed
# calendar behavior has been approved and the Google Workspace BAA is active.
GOOGLE_CALENDAR_STORE_PHI=false
GOOGLE_WORKSPACE_BAA_CONFIRMED=false

# -----------------------------------------------------------------------------
# Vapi webhook authentication and consent-controlled content
# -----------------------------------------------------------------------------
VAPI_HMAC_SECRET=REPLACE_WITH_A_RANDOM_HMAC_SECRET
VAPI_HMAC_SIGNATURE_HEADER=x-vapi-signature
VAPI_HMAC_TIMESTAMP_HEADER=x-vapi-timestamp
VAPI_HMAC_TOLERANCE_SECONDS=300
# Explicit signed-event destination used during assistant provisioning. It is
# derived from PUBLIC_API_URL if omitted, but explicit production config makes
# provider routing easier to audit.
VAPI_WEBHOOK_URL=https://api.example.com/api/webhook/vapi
# Hard call-duration and pre-authorized budget ceilings (60-7200 seconds).
VAPI_MAX_OUTBOUND_CALL_SECONDS=900
# Keep this equal to maxDurationSeconds on every active Vapi assistant.
VAPI_MAX_INBOUND_CALL_SECONDS=900

# Optional platform-funded mode. The API key stays in the deployment secret
# manager and is never stored in a tenant row or returned by the API. Enable it
# in both the API and worker workloads before binding platform resources.
PLATFORM_VAPI_ENABLED=false
# PLATFORM_VAPI_API_KEY=REPLACE_ME
PLATFORM_VAPI_MAX_PHONE_NUMBERS_PER_ORGANIZATION=10
PLATFORM_VAPI_MAX_ASSISTANTS_PER_ORGANIZATION=10

# This controls consent-gated, encrypted transcript extraction into CallLog.
# The webhook inbox retains only an encrypted structural audit envelope.
VAPI_STORE_TRANSCRIPTS=false

# -----------------------------------------------------------------------------
# Sensitive payload retention
# -----------------------------------------------------------------------------
# Production must set each period from the approved record-by-record policy.
# Zero purges eligible content on the next hourly worker pass.
PROVIDER_WEBHOOK_PAYLOAD_RETENTION_DAYS=30
COMMUNICATION_PAYLOAD_RETENTION_DAYS=30
CALL_TRANSCRIPT_RETENTION_DAYS=0
OUTBOX_TERMINAL_RETENTION_DAYS=30
REGISTRATION_REQUEST_RETENTION_DAYS=30

# Development-only bearer fallback. Production requires VAPI_HMAC_SECRET.
# VAPI_WEBHOOK_SECRET=REPLACE_ME

# -----------------------------------------------------------------------------
# Stripe subscriptions and metered billing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Comma-separated overlapping secrets for a webhook-signing-key rotation.
STRIPE_WEBHOOK_SECRETS=
# Pin the API version used by the Stripe account after testing it in staging.
STRIPE_API_VERSION=
STRIPE_EXPECT_LIVEMODE=true
STRIPE_API_TIMEOUT_MS=10000
STRIPE_API_MAX_RETRIES=2
STRIPE_CHECKOUT_TTL_MINUTES=60
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
BILLING_GRACE_PERIOD_DAYS=7
BILLING_MAINTENANCE_ENABLED=true
STRIPE_AUTOMATIC_TAX=false
STRIPE_ALLOW_PROMOTION_CODES=false
STRIPE_CHECKOUT_SUCCESS_URL=https://app.example.com/settings/billing?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=https://app.example.com/settings/billing?checkout=cancelled
STRIPE_PORTAL_RETURN_URL=https://app.example.com/settings/billing

# The keys are application plan IDs. Each metered metric needs both a Stripe
# recurring Price and a Stripe Meter event name. This example covers every
# metric currently emitted by the application. An enabled voice or SMS feature
# must configure every metric its runtime path can emit.
# Keep this JSON on one line.
STRIPE_PLAN_CONFIG_JSON={"starter":{"currency":"INR","basePriceId":"price_REPLACEBASE","licensedPrices":[],"meteredPriceIds":{"voice_seconds":"price_REPLACEVOICE","sms_segments":"price_REPLACESMS","vapi_llm_prompt_tokens":"price_REPLACEVAPIPROMPT","vapi_llm_cached_prompt_tokens":"price_REPLACEVAPICACHEDPROMPT","vapi_llm_completion_tokens":"price_REPLACEVAPICOMPLETION","vapi_tts_characters":"price_REPLACEVAPITTS"},"meterEventNames":{"voice_seconds":"voice_seconds","sms_segments":"sms_segments","vapi_llm_prompt_tokens":"vapi_llm_prompt_tokens","vapi_llm_cached_prompt_tokens":"vapi_llm_cached_prompt_tokens","vapi_llm_completion_tokens":"vapi_llm_completion_tokens","vapi_tts_characters":"vapi_tts_characters"},"entitlements":{"appointments.write":true,"communications.sms":true,"communications.voice":true,"clinics.max":1},"trialDays":14}}

# Immutable local retail-rate versions used for rating and amount budgets.
# Amount is a positive integer minor-unit string; quantity is a positive decimal
# string. Cover every current plan metric and operational-tenant currency, then
# run billing:sync-prices. The numbers below demonstrate valid units only; they
# are not recommended retail rates. Replace them after cost and margin review.
BILLING_PRICE_VERSIONS_JSON=[{"planKey":"starter","metric":"voice_seconds","version":"2026-07-01","currency":"INR","unitAmountMinor":"2","unitQuantity":"1","effectiveFrom":"2026-07-01T00:00:00.000Z","effectiveTo":null},{"planKey":"starter","metric":"sms_segments","version":"2026-07-01","currency":"INR","unitAmountMinor":"100","unitQuantity":"1","effectiveFrom":"2026-07-01T00:00:00.000Z","effectiveTo":null},{"planKey":"starter","metric":"vapi_llm_prompt_tokens","version":"2026-07-01","currency":"INR","unitAmountMinor":"1","unitQuantity":"1000","effectiveFrom":"2026-07-01T00:00:00.000Z","effectiveTo":null},{"planKey":"starter","metric":"vapi_llm_cached_prompt_tokens","version":"2026-07-01","currency":"INR","unitAmountMinor":"1","unitQuantity":"1000","effectiveFrom":"2026-07-01T00:00:00.000Z","effectiveTo":null},{"planKey":"starter","metric":"vapi_llm_completion_tokens","version":"2026-07-01","currency":"INR","unitAmountMinor":"1","unitQuantity":"1000","effectiveFrom":"2026-07-01T00:00:00.000Z","effectiveTo":null},{"planKey":"starter","metric":"vapi_tts_characters","version":"2026-07-01","currency":"INR","unitAmountMinor":"1","unitQuantity":"1000","effectiveFrom":"2026-07-01T00:00:00.000Z","effectiveTo":null}]

# Never set STRIPE_API_BASE_URL in production; production startup restricts the
# API origin to https://api.stripe.com. It exists only for local test doubles.
# STRIPE_API_BASE_URL=http://stripe.test.local

# -----------------------------------------------------------------------------
# Call state and provider migration compatibility
# -----------------------------------------------------------------------------
CALL_STATE_TTL_SECONDS=7200
CALL_STATE_REDIS_TIMEOUT_MS=1500
# Both compatibility bypasses are development-only and should remain false.
ALLOW_LEGACY_PROVIDER_FALLBACK=false
ALLOW_UNENTITLED_DEV_ACCESS=false

# Legacy global provider credentials work only in non-production when the
# fallback above is true. They are separate from PLATFORM_VAPI_API_KEY and must
# not be used as the production platform-funded credential.
# TWILIO_ACCOUNT_SID=REPLACE_ME
# TWILIO_AUTH_TOKEN=REPLACE_ME
# TWILIO_PHONE_NUMBER=REPLACE_ME
# VAPI_API_KEY=REPLACE_ME
# VAPI_PHONE_NUMBER_ID=REPLACE_ME
# VAPI_REMINDER_ASSISTANT_ID=REPLACE_ME

# Retention above intentionally covers only ephemeral payload-bearing records.
# Patient, appointment, audit, usage/cost, backup, legal-hold, and erasure policy
# still require an approved product/legal workflow; see DEPLOYMENT.md.
