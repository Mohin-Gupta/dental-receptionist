{
  "name": "api",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "test": "npm run build && node --test --require ts-node/register tests/*.test.ts",
    "billing:sync-prices": "node dist/billing/syncPriceVersionsCli.js",
    "vapi:bind-platform": "node dist/services/platformVapiProvisioningCli.js",
    "security:encrypt-legacy-secrets": "node dist/ops/encryptLegacySecretsCli.js",
    "dev:worker": "nodemon --watch src --ext ts --exec ts-node src/worker.ts",
    "auth:bootstrap": "ts-node prisma/bootstrapOwner.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.77.7",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "16.3.1",
    "express-rate-limit": "^7.5.1",
    "express": "4.18.2",
    "googleapis": "^134.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^6.10.1",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "zod": "^3.25.76",
    "twilio": "^4.23.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "20.11.0",
    "@types/qrcode": "^1.5.5",
    "@types/twilio": "^3.19.2",
    "nodemon": "3.0.2",
    "prisma": "5.22.0",
    "ts-node": "10.9.2",
    "typescript": "5.3.3"
  }
}
